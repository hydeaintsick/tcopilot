generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskPeriod {
  MORNING
  NOON
  AFTERNOON
  EVENING
  NIGHT
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  telegramUserId BigInt   @unique
  timezone       String   @default("Europe/Paris")
  // Langue d'interface du bot (réponses + boutons). Défaut anglais.
  language       String   @default("en")

  // Compteur incrémental par utilisateur pour les identifiants lisibles des tâches (#1, #2, ...).
  taskSeq        Int      @default(0)

  // Accès premium offert à vie (liste blanche gérée par l'admin).
  isWhitelisted  Boolean  @default(false)
  // Fin de la période d'essai gratuite (null = pas d'essai).
  trialEndsAt    DateTime?
  // Fin de la période d'abonnement payée en cours (null = jamais abonné).
  subscriptionExpiresAt   DateTime?
  // Indique si l'abonnement est renouvelé automatiquement par Telegram.
  subscriptionIsRecurring Boolean  @default(false)
  // Dernier identifiant de paiement Telegram (utile pour les remboursements).
  subscriptionChargeId    String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tasks          Task[]
}

model Task {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  userId      String       @db.ObjectId
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Identifiant lisible et séquentiel par utilisateur (#1, #2, ...). Optionnel pour
  // rester compatible avec les tâches créées avant l'introduction du champ.
  displayId   Int?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  date        DateTime?
  time        String?
  period      TaskPeriod?
  reminderAt  DateTime?
  notifiedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, status])
  @@index([userId, displayId])
  @@index([reminderAt, status, notifiedAt])
}

model Session {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  key   String @unique
  value String
}

/// Journal des questions posées au bot, conservé pour analyse ultérieure
/// (notamment les messages non compris). Volontairement détaché de `User`
/// (pas de relation/cascade) afin de conserver l'historique même après
/// suppression d'un compte.
model QuestionLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  // Identifiants de l'auteur (dénormalisés, sans relation pour éviter la cascade).
  userId         String?  @db.ObjectId
  telegramUserId BigInt
  // Texte brut soumis (message tapé ou transcription du vocal).
  text           String
  // Origine du message : "text" ou "voice".
  source         String
  // Intention détectée par le modèle ("unknown" si non comprise).
  intent         String
  // Raccourci d'analyse : false quand l'intention est "unknown".
  understood     Boolean
  createdAt      DateTime @default(now())

  @@index([understood, createdAt])
  @@index([telegramUserId, createdAt])
}
