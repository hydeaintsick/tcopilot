# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest

# Database (SQLite for MVP)
DATABASE_URL="file:./dev.db"

# Server
PORT=3000

# Webhook (required for production / ngrok dev)
WEBHOOK_URL=https://your-subdomain.ngrok.io/webhook
WEBHOOK_SECRET=your_random_secret_string

# --- Dev setup with ngrok ---
# 1. npm install && npm run db:migrate
# 2. Copy this file to .env and fill in your tokens
# 3. npm run dev
# 4. In another terminal: ngrok http 3000
# 5. Set WEBHOOK_URL to https://<ngrok-id>.ngrok.io/webhook
# 6. Register webhook:
#    curl "https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/setWebhook?url=<WEBHOOK_URL>&secret_token=<WEBHOOK_SECRET>"
