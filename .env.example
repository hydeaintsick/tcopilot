# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest

# Database (MongoDB Atlas connection string)
DATABASE_URL="mongodb+srv://user:password@cluster.xxxxx.mongodb.net/tcopilot?retryWrites=true&w=majority"

# Secret partagé entre Telegram et le webhook (header x-telegram-bot-api-secret-token)
WEBHOOK_SECRET=your_random_secret_string

# Secret pour protéger la route cron (header Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=your_random_cron_secret

# URL publique de l'app (utilisée par le script set-webhook). Optionnel : peut être passée en argument.
PUBLIC_BASE_URL=https://your-app.vercel.app

# URL publique du bot Telegram affichée sur le site vitrine (optionnel)
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/your_bot_username

# URL du canal Telegram vers lequel pointent les boutons d'action du site (optionnel)
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/your_channel

# --- Mise en route ---
# 1. npm install               (génère le client Prisma)
# 2. cp .env.example .env       puis remplis les valeurs
# 3. npm run db:push            (crée les collections dans MongoDB Atlas)
# 4. npm run dev                (site + API en local sur http://localhost:3000)
#
# --- Webhook Telegram (prod) ---
#   npm run set-webhook -- https://your-app.vercel.app
#
# --- Cron des rappels (cron-job.org) ---
#   GET https://your-app.vercel.app/api/cron/reminders
#   Header: Authorization: Bearer <CRON_SECRET>
#   Fréquence : chaque minute
