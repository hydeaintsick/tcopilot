{
  "name": "tcopilot",
  "version": "0.1.0",
  "description": "Assistant personnel intelligent via Telegram + site vitrine Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
